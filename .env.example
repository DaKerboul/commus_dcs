# Database (used by Drizzle CLI and Nuxt runtime)
DATABASE_URL=postgresql://commus:commus@localhost:5432/commus_dcs
NUXT_DATABASE_URL=postgresql://commus:commus@localhost:5432/commus_dcs

# Auth — generate strong values for production: openssl rand -hex 32
NUXT_SESSION_SECRET=your-secret-here-change-me
NUXT_SESSION_PASSWORD=your-session-password-here-change-me
NUXT_ADMIN_PASSWORD=change-me

# Public
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Twitch (optional — disables streamer features when absent)
NUXT_TWITCH_CLIENT_ID=
NUXT_TWITCH_CLIENT_SECRET=

# Set to false to skip auto-migrations at startup (emergency opt-out)
# NUXT_RUN_MIGRATIONS=false
